# ===================================
# Hive Platform — Environment Variables
# Copy this file to .env.local in each app directory
# NEVER commit actual secrets to git
# ===================================

# ─── CONVEX ──────────────────────────────────────────────────────────────────
# From: https://dashboard.convex.dev → your deployment → Settings
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOY_KEY=                          # For CI/CD: convex deploy

# ─── CLERK ───────────────────────────────────────────────────────────────────
# From: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Clerk redirect URLs (App Router)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── CLOUDINARY ──────────────────────────────────────────────────────────────
# From: https://cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=                      # SERVER ONLY — never expose

# Upload presets (create in Cloudinary console → Settings → Upload)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=hive_products_unsigned
CLOUDINARY_SIGNED_UPLOAD_PRESET=hive_docs_signed   # SERVER ONLY

# ─── RAZORPAY ────────────────────────────────────────────────────────────────
# From: https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_       # Public key — safe in browser
RAZORPAY_KEY_SECRET=                        # SERVER ONLY — never expose
RAZORPAY_WEBHOOK_SECRET=                    # SERVER ONLY — from Razorpay webhook settings

# ─── LOGISTICS ───────────────────────────────────────────────────────────────
# Delhivery (primary)
DELHIVERY_API_TOKEN=                        # SERVER ONLY
DELHIVERY_API_BASE_URL=https://track.delhivery.com/api
DELHIVERY_WAREHOUSE_ID=

# Shiprocket (fallback)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=                        # SERVER ONLY

# ─── NOTIFICATIONS ───────────────────────────────────────────────────────────
# WhatsApp Business API (e.g., Interakt / Gupshup)
WHATSAPP_API_KEY=                           # SERVER ONLY
WHATSAPP_API_URL=https://api.interakt.ai/v1/public/message/

# Email (e.g., Resend)
RESEND_API_KEY=                             # SERVER ONLY
EMAIL_FROM=noreply@hive.tailorbee.in

# ─── NOMINATIM / GEOCODING ───────────────────────────────────────────────────
# OSM Nominatim is free but rate-limited — use a custom instance or Geocodify
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Optional: paid geocoding API key for production
GEOCODING_API_KEY=

# ─── APP URLS ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CUSTOMER_APP_URL=http://localhost:3000
NEXT_PUBLIC_BOUTIQUE_APP_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3002

# ─── FEATURE FLAGS ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_WHATSAPP_NOTIFICATIONS=false
